---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Attention & Fonctionnement Cognitif — Screener",
  description = "Outil d'auto-évaluation du fonctionnement attentionnel basé sur l'ASRS v1.1. Non médical.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen font-sans antialiased">
    <div class="mx-auto flex min-h-screen max-w-3xl flex-col px-4 py-6 sm:py-10">
      <header class="mb-8 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="h-8 w-8 rounded-lg bg-brand-500"></div>
          <div class="leading-tight">
            <div class="text-sm font-semibold text-brand-900">
              Attention Screener
            </div>
            <div class="text-xs text-slate-500">
              basé sur l'ASRS v1.1 — non médical
            </div>
          </div>
        </div>
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer class="mt-12 border-t border-slate-200 pt-4 text-xs text-slate-500">
        Cet outil est un auto-questionnaire de screening basé sur l'Adult
        ASRS v1.1 (OMS). Il ne constitue ni un diagnostic, ni un avis
        médical, et ne remplace pas l'évaluation d'un professionnel de
        santé.
      </footer>
    </div>
  </body>
</html>
